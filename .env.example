# App runtime connection — authenticates as aether_app_role, a
# privilege-restricted Postgres role (no DELETE anywhere, no UPDATE on
# append-only tables) created by Alembic migration 0001. The password
# here MUST match AETHER_APP_DB_PASSWORD below, since migration 0001
# sets aether_app_role's actual Postgres password from that variable.
DATABASE_URL=postgresql+asyncpg://aether_app_role:apppassword@postgres:5432/aether

# Migration-only connection — authenticates as the unrestricted
# database owner. Used only by alembic/env.py; migrations need
# CREATE TYPE/TABLE/ROLE privileges aether_app_role intentionally
# lacks. Never used by the running application itself.
MIGRATION_DATABASE_URL=postgresql+asyncpg://aether:password@postgres:5432/aether

# Read directly by migration 0001 (via os.environ, not via Settings —
# migrations run outside the app's normal config/import path) to set
# aether_app_role's actual login password. Must match the password
# embedded in DATABASE_URL above.
AETHER_APP_DB_PASSWORD=apppassword

ANTHROPIC_API_KEY=your_key_here
AETHER_TRUST_STAGE=T0
SYNTHESIS_SCHEDULE_UTC=02:00
SYNTHESIS_THRESHOLD_NODES=20
LOG_LEVEL=INFO
WATCHDOG_CHECK_INTERVAL_MS=1000
DEFAULT_SKILL_TIMEOUT_MS=30000
LLM_MAX_RETRIES=3
LLM_CONTEXT_TOKEN_BUDGET=8000
